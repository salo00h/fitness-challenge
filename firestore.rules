rules_version = '2';

// ============================================================================
// Fitness Challenge - Firestore Security Rules (TRANSITIONAL / EMERGENCY)
// المشروع: fitness-challenge-6061e
//
// ⚠️ هذه القواعد انتقالية مؤقتة فقط - وليست الحل النهائي.
//
// السبب: التطبيق الحي الذي تستخدمه صفاء وسحر الآن فعليًا (في التحدي الثاني)
// ما زال يعمل بالنظام القديم (بدون Firebase Authentication حقيقية) - الطلبات
// القادمة منه لا تحمل أي هوية موقّعة (request.auth دائمًا null). لذلك لا يمكن
// لهذه القواعد التمييز بين "أنا" و"مشاركة أخرى" بأمان كامل بعد - هذا هو بالضبط
// سبب وجود خطة الانتقال الكاملة إلى Firebase Auth في:
//   firestore.rules.production-after-auth-migration
// والتي يجب نشرها بدل هذا الملف بعد: تفعيل Email/Password في Console، تشغيل
// الترحيل، واختبار تسجيل الدخول الحقيقي (راجع FIREBASE_SECURITY_SETUP.md).
//
// ما تفعله هذه القواعد الانتقالية تحديدًا (أفضل من Test Mode المفتوح بالكامل):
//   - تمنع أي قراءة/كتابة على أي Collection غير معروفة صراحة.
//   - تمنع حذف participants و game-state نهائيًا (لا حذف تقدم أو اقتصاد).
//   - تمنع حذف كل التمارين دفعة واحدة من exercises (حماية إضافية).
//   - تمنع أي وصول لـ roles/public-profiles/legacy-participants حتى تكتمل
//     الهجرة الحقيقية (لا داعي لفتحها الآن، لا يستخدمها التطبيق الحالي).
//   - تتحقق من الشكل الأساسي لبيانات participants (لا تسمح بوثيقة بلا name).
//   - محكومة بتاريخ صلاحية قصير (14 يومًا) على عمليات الكتابة كشبكة أمان
//     إضافية تجبر إكمال الانتقال الحقيقي بدل ترك هذا الوضع الانتقالي دائمًا.
//
// ما لا تستطيع هذه القواعد ضمانه (قيد فعلي حقيقي بدون Auth):
//   - منع مشاركة من تعديل بيانات مشاركة أخرى بالاسم - غير ممكن تقنيًا بدون
//     هوية موقّعة، وهذا وضع موجود أصلًا حتى في Test Mode الحالي. الحل الوحيد
//     هو إكمال الانتقال لـ Firebase Auth (الخطة جاهزة، تنتظر فقط تفعيل
//     Email/Password من Firebase Console ثم تشغيل الاختبارات).
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // نهاية الفترة الانتقالية: بعدها تُرفض كل الكتابات تلقائيًا كحماية إضافية
    // (اضبطي هذا التاريخ للأمام فقط إذا احتجتِ وقتًا إضافيًا حقيقيًا للانتقال).
    function withinTransitionWindow() {
      return request.time < timestamp.date(2026, 8, 2);
    }

    // ------------------------------------------------------------------
    // exercises: التمارين + بيانات التحدي. القراءة والكتابة مفتوحتان مؤقتًا
    // (تمامًا كوضعها الحالي الفعلي بدون Auth) حتى لا يتوقف admin.html، لكن
    // مع منع حذف كل شيء دفعة واحدة.
    // ------------------------------------------------------------------
    match /exercises/{exerciseId} {
      allow read: if true;
      allow create, update: if withinTransitionWindow();
      allow delete: if false;
    }

    // ------------------------------------------------------------------
    // participants/{legacyId}: حسابات المشاركات الحالية (مبنية على الاسم).
    // القراءة/الكتابة مفتوحة مؤقتًا (تطابق الواقع الحالي فعليًا بدون Auth)
    // لضمان استمرار تسجيل الدخول وحفظ done/avatar، لكن:
    //   - يُمنع الحذف نهائيًا.
    //   - يجب أن تبقى الوثيقة تحمل حقل name نصيًا (حماية أساسية من junk data).
    // ------------------------------------------------------------------
    match /participants/{participantId} {
      allow read: if true;
      allow create, update: if withinTransitionWindow() &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0;
      allow delete: if false;
    }

    // ------------------------------------------------------------------
    // notifications: رسائل داخل التطبيق. غير حساسة (ليست تقدمًا أو اقتصادًا)،
    // تبقى كما هي (قراءة/كتابة/حذف) حتى لا تنكسر شاشة الرسائل حاليًا.
    // ------------------------------------------------------------------
    match /notifications/{notificationId} {
      allow read: if true;
      allow create, update, delete: if withinTransitionWindow();
    }

    // ------------------------------------------------------------------
    // game-state/{legacyId}: جواهر/XP إضافية/عجلة الحظ. تبقى قابلة للقراءة
    // والكتابة (كالواقع الحالي) لكن يُمنع حذفها نهائيًا (لا تصفير اقتصاد).
    // ------------------------------------------------------------------
    match /game-state/{userId} {
      allow read: if true;
      allow create, update: if withinTransitionWindow();
      allow delete: if false;
    }

    // ------------------------------------------------------------------
    // مجموعات نظام Firebase Auth الجديد (غير مُفعّلة بعد في الكود الحي) -
    // تبقى مغلقة تمامًا حتى تكتمل الهجرة الحقيقية ويُنشر
    // firestore.rules.production-after-auth-migration بدل هذا الملف.
    // ------------------------------------------------------------------
    match /public-profiles/{userId} {
      allow read, write: if false;
    }
    match /legacy-participants/{legacyId} {
      allow read, write: if false;
    }
    match /roles/{userId} {
      allow read, write: if false;
    }

    // ------------------------------------------------------------------
    // أي مسار آخر غير مذكور أعلاه: رفض كامل صراحة.
    // ------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
